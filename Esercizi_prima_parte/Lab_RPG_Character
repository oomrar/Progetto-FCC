full_dot = '●'
empty_dot = '○'

def create_charcter ( name, forza, intelligenza, carisma):
    if not isinstance(name, str):
        return "The character name should be a string"
    if name == "":
        return "The character name should not be empty"
    if len(name) > 10:
        return "The character name should not be longer than 10 characters"
    if " " in name:
        return "The character name should not contain spaces"
    if not isinstance (forza, int) or not isinstance (intelligenza, int) or not isinstance (carisma, int):
        return "The character attributes should be integers"
    if forza < 1 or intelligenza < 1 or carisma < 1:
        return "The character attributes should be no less than 1"
    if forza > 4 or intelligenza > 4 or carisma > 4:
        return "The character attributes should be no more than 4"
    if forza + intelligenza + carisma != 7:
        return "The character attributes should sum up to 7"
    
    riga1 = name
    riga2 = "Forza: " + full_dot * forza + empty_dot * (10 - forza)
    riga3 = "Intelligenza: " + full_dot * intelligenza + empty_dot * (10 - intelligenza)
    riga4 = "Carisma: " + full_dot * carisma + empty_dot * (10 - carisma)
    return riga1 + "\n" + riga2 + "\n" + riga3 + "\n" + riga4 + "\n"

print (create_charcter("Omar", 4, 2, 1))